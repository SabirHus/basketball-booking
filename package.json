{
  "name": "basketball-booking",
  "version": "1.0.0",
  "private": true,
  "description": "Full stack basketball booking app",
  "scripts": {
    "install-all": "npm install && cd client && npm install && cd ../server && npm install",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "dependencies": {
    "cloudinary": "^1.41.3",
    "cors": "^2.8.6",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "leaflet": "^1.9.4",
    "leaflet-geosearch": "^4.2.2",
    "lucide-react": "^1.7.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "react-leaflet": "^5.0.0",
    "resend": "^6.9.3",
    "stripe": "^20.4.0"
  }
}
